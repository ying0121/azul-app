# Production / packaged app API URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5005

# Dev proxy target (used by vite.config.ts when VITE_API_BASE_URL is empty)
VITE_API_PROXY_TARGET=http://localhost:5005

# Set to "true" to use mock data when API is unavailable
VITE_USE_MOCK=true

# IANA timezone used for appointment date filters (clinic local date)
VITE_CLINIC_TIMEZONE=America/New_York

# Note: .env.development overrides VITE_API_BASE_URL to "" in dev for browser CORS proxy

# Daily email is sent through the backend API:
# POST /daily-huddle/daily-email
# Configure SMTP credentials on the server, not in the frontend.
