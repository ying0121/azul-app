# Backend API base URL (required for production / npm run dist builds)
# No trailing slash. Example: https://ehr.example.com
VITE_API_BASE_URL=http://127.0.0.1:5005

# Dev proxy target (npm run dev / npm run dev:web)
# Usually the same host as VITE_API_BASE_URL. Used by vite.config.ts when VITE_API_USE_PROXY=true.
VITE_API_PROXY_TARGET=http://127.0.0.1:5005

# Set to "true" to use mock data instead of the API
VITE_USE_MOCK=false

# IANA timezone for appointment date filters (clinic local date)
VITE_CLINIC_TIMEZONE=America/New_York

# Daily email is sent through the backend API:
# POST /daily-huddle/daily-email
# Configure SMTP credentials on the server, not in the frontend.
